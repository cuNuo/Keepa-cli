{
  "id": "category_finder_scaffold",
  "description": "从 category 生成 Finder selection scaffold。",
  "command": "categories.finder-selection",
  "params": {
    "category": "1055398",
    "domain": "US",
    "per_page": 25,
    "sales_rank_max": 15000,
    "min_reviews": 100
  },
  "assertions": [
    {"path": "ok", "equals": true},
    {"path": "data.view", "equals": "finder_selection_scaffold"},
    {"path": "data.selection.categories_include.0", "equals": 1055398},
    {"path": "data.selection.current_SALES_lte", "equals": 15000},
    {"path": "data.selection.current_COUNT_REVIEWS_gte", "equals": 100},
    {"path": "data.selection.perPage", "equals": 25},
    {"path": "data.next_actions.0.tool", "equals": "finder.query"},
    {"path": "data.data_quality.confidence", "equals": "high"},
    {"path": "data.evidence_index.selection.path", "equals": "selection"}
  ]
}
