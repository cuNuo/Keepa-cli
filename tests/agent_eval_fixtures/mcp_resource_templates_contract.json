{
  "id": "mcp_resource_templates_contract",
  "description": "MCP resources/templates/list 暴露 schema、fixture 与 chunk/output 模板，便于 Agent 按需读取资源。",
  "kind": "mcp",
  "method": "resources/templates/list",
  "params": {},
  "assertions": [
    {"path": "result.resourceTemplates", "length_min": 13},
    {"path": "result.resourceTemplates", "contains_item": {"uriTemplate": "keepa://schema/{name}"}},
    {"path": "result.resourceTemplates", "contains_item": {"uriTemplate": "keepa://fixtures/{name}"}},
    {"path": "result.resourceTemplates", "contains_item": {"uriTemplate": "keepa://cache-key/{command}/{encoded_params}"}},
    {"path": "result.resourceTemplates", "contains_item": {"uriTemplate": "keepa://research/{cache_key}"}},
    {"path": "result.resourceTemplates", "contains_item": {"uriTemplate": "keepa://research/{cache_key}/brief"}},
    {"path": "result.resourceTemplates", "contains_item": {"uriTemplate": "keepa://research/{cache_key}/graph"}},
    {"path": "result.resourceTemplates", "contains_item": {"uriTemplate": "keepa://graphs/{root}"}},
    {"path": "result.resourceTemplates", "contains_item": {"uriTemplate": "keepa://toolsets/{toolset}"}},
    {"path": "result.resourceTemplates", "contains_item": {"uriTemplate": "keepa://tools/{name}"}},
    {"path": "result.resourceTemplates", "contains_item": {"uriTemplate": "keepa://prompts/{name}"}},
    {"path": "result.resourceTemplates", "contains_item": {"uriTemplate": "keepa://asin/{asin}/fixture"}},
    {"path": "result.resourceTemplates", "contains_item": {"uriTemplate": "keepa://evidence/{encoded_logical_path}"}},
    {"path": "result.resourceTemplates", "contains_item": {"uriTemplate": "keepa://zread/wiki/page/{slug_or_file}"}},
    {"path": "result.resourceTemplates", "contains_item": {"uriTemplate": "keepa://chunk/{encoded_path}"}},
    {"path": "result.resourceTemplates", "contains_item": {"uriTemplate": "keepa://output/{encoded_path}"}}
  ]
}
