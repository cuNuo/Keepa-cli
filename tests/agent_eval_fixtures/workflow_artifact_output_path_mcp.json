{
  "id": "workflow_artifact_output_path_mcp",
  "description": "MCP workflow resolver 可把 artifact.output.path 续接到 brief 与 reports 本地链路。",
  "kind": "mcp_session",
  "steps": [
    {
      "id": "brief-from-artifact-path",
      "method": "tools/call",
      "params": {
        "name": "research_brief_export",
        "arguments": {
          "artifact": {"output": {"path": "tests/fixtures/agent_eval_products_compare_output.json"}},
          "title": "Artifact Path Brief"
        }
      }
    },
    {
      "id": "report-from-artifact-path",
      "method": "tools/call",
      "params": {
        "name": "reports_build",
        "arguments": {
          "artifact": {"data": {"output": {"path": "tests/fixtures/agent_eval_products_compare_output.json"}}},
          "format": "json",
          "title": "Artifact Path Report"
        }
      }
    }
  ],
  "assertions": [
    {"path": "ok", "equals": true},
    {"path": "responses", "length": 2},
    {"path": "responses.0.result.structuredContent.ok", "equals": true},
    {"path": "responses.0.result.structuredContent.command", "equals": "research_brief.export"},
    {"path": "responses.0.result.structuredContent.data.workflow_resolution.resolved.0.kind", "equals": "path"},
    {"path": "responses.0.result.structuredContent.data.workflow_resolution.resolved.0.path", "contains": "agent_eval_products_compare_output.json"},
    {"path": "responses.0.result.structuredContent.data.brief.input_summary.research_graph_count", "min": 1},
    {"path": "responses.1.result.structuredContent.ok", "equals": true},
    {"path": "responses.1.result.structuredContent.command", "equals": "reports.build"},
    {"path": "responses.1.result.structuredContent.data.workflow_resolution.resolved.0.kind", "equals": "path"},
    {"path": "responses.1.result.structuredContent.data.research_graph.entity_counts.product", "min": 3}
  ]
}
