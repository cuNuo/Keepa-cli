{
  "id": "research_graph_merge",
  "description": "合并类目候选、商品对比和卖家输出中的 research_graph。",
  "command": "research_graph.merge",
  "params": {
    "input": [
      "tests/fixtures/agent_eval_category_search_output.json",
      "tests/fixtures/agent_eval_products_compare_output.json",
      "tests/fixtures/agent_eval_seller_output.json"
    ],
    "root": "agent_selection_research"
  },
  "assertions": [
    {"path": "ok", "equals": true},
    {"path": "data.view", "equals": "research_graph_merge"},
    {"path": "data.input_graph_count", "min": 3},
    {"path": "data.summary.entity_counts.category", "min": 5},
    {"path": "data.summary.entity_counts.product", "min": 3},
    {"path": "data.summary.entity_counts.seller", "min": 1},
    {"path": "data.summary.entity_counts.research_graph", "equals": 1},
    {"path": "data.summary.diagnostics.highest_source_weight", "min": 1},
    {"path": "data.diagnostics.highest_source_weight", "min": 1},
    {"path": "data.graph.sources.0.source_weight", "min": 1},
    {"path": "data.graph.sources", "length_min": 3},
    {"path": "data.graph.edges.0.type", "contains_any": ["includes_graph", "buybox_sold_by", "in_category", "matched_category", "sells_product"]},
    {"path": "data.data_quality.confidence", "equals": "high"},
    {"path": "data.evidence_index.diagnostics.path", "equals": "diagnostics"},
    {"path": "data.evidence_index.graph.path", "equals": "graph"}
  ]
}
