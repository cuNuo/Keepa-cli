{
  "id": "category_term_candidates",
  "description": "根据关键词找类目并给出候选 category。",
  "command": "categories.search",
  "params": {
    "term": "home kitchen",
    "domain": "US",
    "fixture": "category_search_home.json"
  },
  "assertions": [
    {"path": "ok", "equals": true},
    {"path": "data.view", "equals": "category_search"},
    {"path": "data.category_candidate_count", "min": 1},
    {"path": "data.category_candidates.0.category_id", "equals": "1055398"},
    {"path": "data.category_candidates.0.next_actions.0.tool", "equals": "categories.products"},
    {"path": "data.agent_brief.key_facts.top_category_id", "equals": "1055398"},
    {"path": "data.data_quality.confidence", "equals": "high"},
    {"path": "data.evidence_index.category_candidates.path", "equals": "category_candidates"}
  ]
}
