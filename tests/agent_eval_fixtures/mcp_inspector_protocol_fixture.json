{
  "id": "mcp_inspector_protocol_fixture",
  "description": "MCP Inspector 风格协议冒烟：初始化、分页发现、资源/提示词发现、ping 与 tools/call 工具错误。",
  "kind": "mcp_session",
  "steps": [
    {"id": "inspector-initialize", "method": "initialize", "params": {}},
    {"id": "inspector-tools-page", "method": "tools/list", "params": {"toolset": "all", "limit": 2}},
    {"id": "inspector-resources-page", "method": "resources/list", "params": {"limit": 2}},
    {"id": "inspector-prompts-page", "method": "prompts/list", "params": {"limit": 2}},
    {"id": "inspector-templates-page", "method": "resources/templates/list", "params": {"limit": 1}},
    {
      "id": "inspector-invalid-tool-args",
      "method": "tools/call",
      "params": {
        "name": "categories_search",
        "arguments": {"domain": "US", "extra": true}
      }
    },
    {"id": "inspector-ping", "method": "ping", "params": {}}
  ],
  "assertions": [
    {"path": "kind", "equals": "mcp_session"},
    {"path": "responses", "length": 7},
    {"path": "responses.0.result.protocolVersion", "equals": "2025-11-25"},
    {"path": "responses.0.result.serverInfo.name", "equals": "keepa_mcp"},
    {"path": "responses.0.result.serverInfo.title", "equals": "Keepa CLI MCP"},
    {"path": "responses.0.result.capabilities.tools.listChanged", "equals": false},
    {"path": "responses.1.result.tools", "length": 2},
    {"path": "responses.1.result.tools.0.name", "equals": "context_policy"},
    {"path": "responses.1.result.tools.0.title", "equals": "Keepa Context Policy"},
    {"path": "responses.1.result.tools.0.execution.taskSupport", "equals": "forbidden"},
    {"path": "responses.1.result.tools.0.annotations.openWorldHint", "equals": false},
    {"path": "responses.1.result.tools.0.outputSchema.required", "contains": "budget_ledger"},
    {"path": "responses.1.result._meta.total_count", "min": 30},
    {"path": "responses.1.result._meta.has_more", "equals": true},
    {"path": "responses.1.result._meta.cursor_schema_version", "equals": "2026-05-12.1"},
    {"path": "responses.1.result._meta.cursor_collection", "equals": "tools"},
    {"path": "responses.2.result.resources", "length": 2},
    {"path": "responses.2.result.resources.0.title", "contains": "Products"},
    {"path": "responses.2.result._meta.has_more", "equals": true},
    {"path": "responses.3.result.prompts", "length": 2},
    {"path": "responses.3.result.prompts.0.title", "contains": "Keepa"},
    {"path": "responses.3.result._meta.has_more", "equals": true},
    {"path": "responses.4.result.resourceTemplates", "length": 1},
    {"path": "responses.4.result.resourceTemplates.0.title", "contains": "Schema"},
    {"path": "responses.5.result.isError", "equals": true},
    {"path": "responses.5.result.structuredContent.error.kind", "equals": "invalid_arguments"},
    {"path": "responses.5.result.structuredContent.error.details.errors", "contains": "missing required argument: term"},
    {"path": "responses.5.result.structuredContent.error.details.next_action", "contains": "tools/list"},
    {"path": "responses.6.result", "equals": {}}
  ]
}
